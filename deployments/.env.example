# Copy to deployments/.env on the box (gitignored). docker compose reads it
# automatically for ${...} substitution in app-staging.yaml.

# Commit SHA of the images to run — must match a pushed GHCR tag. Never 'latest'.
IMAGE_TAG=

# Postgres container credentials. Must match the database_url in
# secrets/staging-secrets.yaml (host = postgres, port = 5432).
POSTGRES_USER=akademi
POSTGRES_PASSWORD=
POSTGRES_DB=akademi
